# ==============================================================================
# BC/, PHARLAP/, UTIL/, ZINC/, Documents/ are intentionally NOT listed here
# — their contents are always tracked
# ==============================================================================

# ==============================================================================
# st/ — build artifacts only
# ==============================================================================

# Compiled objects
st/**/*.obj

# Libraries
st/**/*.lib

# DLLs
st/**/*.dll

# Executables
st/**/*.exe

# Linker map / debug symbols
st/**/*.map
st/**/*.sym

# Borland IDE desktop state
st/**/*.dsk

# MacOS Finder metadata
.DS_Store

# Claude Code working state (worktrees, session data)
.claude/

# ==============================================================================
# st/bin/ — runtime artifacts and generated files
# ==============================================================================

# Resource editor backup copies
st/bin/RES.BK*

# Compiled Zinc binary resource (generated by resource compiler)
st/bin/RES.DAT

# Generated source copies (canonical versions live in source/ and include/)
st/bin/res.cpp
st/bin/res.hpp

# Generated help database (built from source/help.txt via genhelp)
st/bin/help.dat

# Compiled telephony database (built from ddi.inf + ddn.inf + local.inf)
st/bin/PH_INFO.DAT

# Runtime transaction database and log (created/written at runtime)
st/bin/RX.DAT
st/bin/RX.IDX
st/bin/RX.STA
st/bin/LOG.DAT
