# ==============================================================================
# vendor/ (bc, pharlap, util, zinc) and Documents/ are intentionally NOT listed here
# — their contents are always tracked
# ==============================================================================

# ==============================================================================
# st/ — build artifacts only
# ==============================================================================

# Compiled objects
st/**/*.obj

# Libraries
st/**/*.lib

# DLLs
st/**/*.dll

# Executables
st/**/*.exe
# ...except the build-helper compilers: building them in CI is fragile under
# Windows DOSBox-X, and the MAKEFILE assumes they already exist. Track the
# Pharlap-bound binaries so a fresh checkout (incl. CI) can run them directly.
!st/util/ini2cfg/INI2CFG.EXE
!st/util/inf2dat/INF2DAT.EXE

# Linker map / debug symbols
st/**/*.map
st/**/*.sym

# Borland IDE desktop state
st/**/*.dsk

# util build artifacts
st/util/**/obj/
st/util/inf2dat/PH_INFO.DAT
st/util/ini2cfg/st.cfg

# util runtime data -- canonical sources in util/inf2dat/ and util/ini2cfg/;
# all other util/ and test/ copies are build outputs / not tracked.
# st.cfg in every util subdir is distributed by the MAKEFILE from ini2cfg.
st/util/*/st.cfg
st/util/setup/ddi.inf
st/util/setup/ddn.inf
st/util/setup/local.inf
st/util/setup/st.ini
st/util/defpwd/st.ini
st/test/ph_eng/ddi.inf
st/test/ph_eng/ddn.inf
st/test/ph_eng/local.inf
st/test/ph_eng/tv/ddi.inf
st/test/ph_eng/tv/ddn.inf
st/test/ph_eng/tv/local.inf

# MacOS Finder metadata
.DS_Store

# Claude Code working state (worktrees, session data)
.claude/

# ==============================================================================
# st/bin/ — entirely a build-output / runtime directory; nothing tracked here.
# Canonical sources for runtime data files live in st/data/ and are copied
# to bin/ by the MAKEFILE on each build.
# ==============================================================================
st/bin/

# Versioned bin snapshots (e.g. st/_bin/, st/_bin-2.50.0/)
st/_bin/
st/_bin-*/

# Release builds directory
_releases/


# Generated .docx manuals — wiki build outputs (build-docs.sh), not tracked.
# Regenerate from wiki/ vault; originals (help.doc, STC.doc, STC.rtf) stay tracked.
st/docs/archive/*.docx
# help.hpp is emitted by genhelp alongside help.dat (into st/include/).
st/include/help.hpp

# ==============================================================================
# Headless build logs (make-headless.sh / run-headless.sh)
# ==============================================================================
# DOSBox-X writes uppercase, the host script targets lowercase. List both
# so case-sensitive filesystems don't leak either.
build.log
BUILD.LOG
st/build.log
st/BUILD.LOG
run*.log
RUN*.LOG

# ==============================================================================
# DOSBox-X capture directory (screenshots / AVI / WAV, configured via
# [dosbox] captures = capture in dosbox-x.conf)
# ==============================================================================
capture/

# ==============================================================================
# Host-side scratch images (ad-hoc PNG drops at repo root)
# ==============================================================================
/page*.png
/page*.PNG
# Generated documentation outputs (build-docs.sh / build-docs.ps1)
st/docs/build/

# Obsidian vault (auto-created on first open, user-specific)
.obsidian/

# Demo-engine debug breadcrumb (DEMO_ENGINE::ParsePhones -> phones.dbg)
*.dbg
*.DBG

# DOSBox-X temp lock files (created when ini files are open)
st/**/.!*.ini

# Host-side test binaries
/test_pdf
