# --- [ OBJS_REAL ] ----------------------------------------------------------
# Real-hardware-only objects (real_dos\).  These are linked ONLY into the
# non-demo (REAL_DOS) build.  The demo_dos build excludes them entirely --
# the real engine, dongle and EEPROM are deactivated
# (see MINI_SMARTTAR_PLAN P1.3).
# rt_eng is referenced only by MakeEngine()'s DEMO_DOS-gated branch; dongle
# and eeprom are referenced by st.cpp's DEMO_DOS-gated paths.
OBJS_REAL=$(OBJ_DIR)\rt_eng.$(OBJ_EXT)	\
	 $(OBJ_DIR)\dongle.$(OBJ_EXT)	\
	 $(OBJ_DIR)\eeprom.$(OBJ_EXT)	\
	 $(OBJ_DIR)\bankstm2.$(OBJ_EXT)

# LINK_OBJS = the object set actually linked for this variant.
!if $d(IS_DEMO)
LINK_OBJS=$(OBJS)
!else
LINK_OBJS=$(OBJS) $(OBJS_REAL)
!endif

DLLS=$(BIN_DIR)\pr_sr80.$(DLL_EXT)	\
	$(BIN_DIR)\pr_dr80.$(DLL_EXT)  \
	$(BIN_DIR)\pr_lin80.$(DLL_EXT) \
	$(BIN_DIR)\pr_drpre.$(DLL_EXT) \
	$(BIN_DIR)\pr_dr40.$(DLL_EXT)  \
	$(BIN_DIR)\pr_sr40.$(DLL_EXT)  \
	$(BIN_DIR)\pr_dr18.$(DLL_EXT)  \
	$(BIN_DIR)\pr_sr28.$(DLL_EXT)  \
	$(BIN_DIR)\pr_dreme.$(DLL_EXT) \
	$(BIN_DIR)\pr_drhal.$(DLL_EXT)


.c.dll:
	$(CC) $(DLL_CC_OPTIONS) {$< }
	@move $&.$(OBJ_EXT)  $(OBJ_DIR)
	@move $&.$(DLL_EXT)  $(BIN_DIR)
	@move $&.$(LIB_EXT)   $(LIB_DIR)

.cpp.obj:
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**

.asm.obj:
	$(ASM) $(ASM_OPTS) $<, $@

$(BIN_DIR)\$(EXE_FILE): $(BIN_DIR)\$(HELP_FILE) $(BIN_DIR)\$(RES_FILE) $(BIN_DIR)\st.ini $(BIN_DIR)\demo.ini $(BIN_DIR)\phones.csv $(BIN_DIR)\local.inf $(BIN_DIR)\ddn.inf $(BIN_DIR)\ddi.inf $(LINK_OBJS) $(DLLS)
	$(LINK) $(LINK_OPTS) @&&!
$(STARTUP_OBJS) $(LINK_OBJS)
$*, ,$(LIBS), $(DEF_FILE)
!
!if $d(RUN)
	$(BIND) $(RTK_DIR)\run286b $(BIN_DIR)\$(EXE_FILE) -dll $(RTK_DIR)\doscalls $(RTK_DIR)\int33
	cfig286 $(BIN_DIR)\$(EXE_FILE) -NISTACK 10 -LDTSIZE 4096
!endif

$(BIN_DIR)\$(HELP_FILE): $(RES_DIR)\help.txt
	@genhelp $(RES_DIR)\help.txt $(HELP_FILE) > NUL
	@move $(HELP_FILE)	$(BIN_DIR) > NUL
	@move help.hpp $(INCLUDE_DIR) > NUL

# Zinc binary resource — the canonical RES.DAT is a tracked binary source
# in $(RES_DIR)\, edited interactively via DESIGN.EXE (Zinc Designer).
# This rule republishes it into $(BIN_DIR) so the runtime app finds it.
$(BIN_DIR)\$(RES_FILE): $(RES_DIR)\$(RES_FILE)
	@copy $(RES_DIR)\$(RES_FILE) $(BIN_DIR)\$(RES_FILE) > NUL

# Application config & telephony data -- ST.INI is the single config source;
# .inf files are the canonical telephony place databases (mini-smarttar:
# inf2dat dropped, binary PH_INFO.DAT eliminated).  PH_ENGINE::Load()
# falls back to reading .inf files directly when PH_INFO.DAT is absent.
$(BIN_DIR)\st.ini: st.ini
	@copy st.ini $(BIN_DIR)\st.ini > NUL
$(BIN_DIR)\demo.ini: demo.ini
	@copy demo.ini $(BIN_DIR)\demo.ini > NUL
# Real-number dataset for DEMO_ENGINE -- DEMO_ENGINE::ParsePhones
# reads it from bin/ at startup.
$(BIN_DIR)\phones.csv: phones.csv
	@copy phones.csv $(BIN_DIR)\phones.csv > NUL
# Telephony place databases -- PH_ENGINE::Load() reads these from
# bin/ when PH_INFO.DAT is absent (falls back to .inf direct load).
$(BIN_DIR)\local.inf: local.inf
	@copy local.inf $(BIN_DIR)\local.inf > NUL
$(BIN_DIR)\ddn.inf: ddn.inf
	@copy ddn.inf $(BIN_DIR)\ddn.inf > NUL
$(BIN_DIR)\ddi.inf: ddi.inf
	@copy ddi.inf $(BIN_DIR)\ddi.inf > NUL

# ============================================================================
# Explicit per-file source-path mapping
# ----------------------------------------------------------------------------
# Borland MAKE 3.6 doesn't support .PATH.x (see note near the top), so we
# tell MAKE where each source file lives via explicit dependency
# declarations. The .cpp.obj / .c.dll suffix rules above supply the build
# commands; these declarations only point MAKE at the source for each
# target. Order mirrors the OBJS / DLLS lists for 1-to-1 cross-checking.
#
# This block MUST live after the EXE rule so MAKE's default target stays
# $(BIN_DIR)\$(EXE_FILE) — Borland MAKE picks the first target it sees as
# default, and bodyless dependency declarations as default = silent no-op.
# ============================================================================

# --- OBJs (cpp -> obj) ---
# Each rule carries its own body because Borland MAKE 3.6's .cpp.obj
# suffix rule does not fire for path-prefixed targets (e.g. build\foo.obj).
# DLL targets DO work with the .c.dll suffix rule alone, but .cpp/.obj
# requires the explicit body to actually compile.
$(OBJ_DIR)\st.obj:       $(SOURCE_DIR)\st.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\bdisplay.obj: $(SOURCE_DIR)\ui\bdisplay.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\calc.obj:     $(SOURCE_DIR)\calc.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\calendar.obj: $(SOURCE_DIR)\calendar.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\cfg.obj:      $(SOURCE_DIR)\cfg.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\control.obj:  $(SOURCE_DIR)\ctrl\control.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\cstr.obj:     $(SOURCE_DIR)\cstr.cpp
