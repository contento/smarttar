.autodepend
.swap

# Borland MAKE 3.6 default suffix list is .exe .obj .asm .c — .cpp is
# not included. Declare it (and the other extensions used in suffix
# rules below) so '.cpp.obj' / '.c.dll' / '.asm.obj' rules match.
.SUFFIXES: .cpp .c .asm .obj .dll

APP=st

EXE_FILE=$(APP).exe
HELP_FILE=help.dat
RES_FILE=res.dat

OBJ_EXT=obj
LIB_EXT=lib
DLL_EXT=dll

SOURCE_DIR=src
OBJ_DIR=build
BIN_DIR=bin
LIB_DIR=lib
INCLUDE_DIR=include
RES_DIR=res

# NOTE: Borland MAKE 3.6 (bundled with BC 3.1) does NOT support the
# .PATH.x directive — it was added in MAKE 4.0+. The lines below are
# silently ignored by MAKE 3.6, kept here as documentation of the
# source-tree layout for human readers (and any future MAKE 4.0+ build).
# The actual source paths are resolved via explicit per-file dependency
# declarations further down (the '$(OBJ_DIR)\foo.obj: $(SOURCE_DIR)\…'
# block under the suffix rules).
.PATH.c  =$(SOURCE_DIR)\pr
.PATH.cpp=$(SOURCE_DIR);$(SOURCE_DIR)\core;$(SOURCE_DIR)\demo_dos;$(SOURCE_DIR)\real_dos;$(SOURCE_DIR)\ph;$(SOURCE_DIR)\db;$(SOURCE_DIR)\pr;$(SOURCE_DIR)\ui;$(SOURCE_DIR)\mb;$(SOURCE_DIR)\tb;$(SOURCE_DIR)\ct;$(SOURCE_DIR)\ctrl
.PATH.asm=$(SOURCE_DIR)
.PATH.obj=$(OBJ_DIR)
.PATH.dll=$(BIN_DIR)
.PATH.lib=$(LIB_DIR)
.PATH.txt=$(RES_DIR)

CC=bcc286
ASM=tasm
LINK=tlink
BIND=bind286
RTK_DIR=..\vendor\pharlap\bin

# DEMO_DOS / REAL_DOS are passed via the bat file (makedemo_dos.bat passes
# -DDEMO_DOS; makereal_dos.bat passes -DREAL_DOS).  We detect which variant
# we are building to select the link-object set.
IS_DEMO=
!if $d(DEMO_DOS)
IS_DEMO=1
!endif

# Pass the variant define (-DDEMO_DOS or -DREAL_DOS) through to the compiler
# so #if defined(DEMO_DOS) / #if defined(REAL_DOS) gates work in source.
VARIANT_DEF=
!if $d(DEMO_DOS)
VARIANT_DEF=-DDEMO_DOS
!else
!if $d(REAL_DOS)
VARIANT_DEF=-DREAL_DOS
!endif
!endif


# TLINK library search path. The -L in st.cfg is BCC286's (forwarded to
# TLINK only when BCC286 invokes the linker). We call TLINK directly, so
# we must pass the lib path here too.
LINK_LIBPATH=/L..\vendor\bc\lib;..\vendor\pharlap\lib;..\vendor\zinc\lib;lib

!if $d(DEBUG)
OBJ_CC_OPTIONS= -c +$(APP).cfg $(VARIANT_DEF) -v
DLL_CC_OPTIONS= -dll +$(APP).cfg $(VARIANT_DEF) -DNDEBUG -v
LINK_OPTS=/c /C /x /v $(LINK_LIBPATH)
ASM_OPTS=/mx /zi
!else
OBJ_CC_OPTIONS= -c +$(APP).cfg $(VARIANT_DEF) -DNDEBUG
DLL_CC_OPTIONS= -dll +$(APP).cfg $(VARIANT_DEF) -DNDEBUG
LINK_OPTS=/c /C /s $(LINK_LIBPATH)
ASM_OPTS=/mx
!endif

# Borland C++ 3.1 startup module for Pharlap 286 protected mode.
# Lives in pharlap/LIB/ — full path needed because TLINK's /L only
# applies to .lib files, not .obj files.
STARTUP_OBJS=..\vendor\pharlap\lib\c0pl.obj
LIBS=phapi d16_zil d16_gfx bc_16gfx emu286 emu mathl bcl286 ptclassl pbidsl
DEF_FILE=$(APP).def

# --- [ OBJS ] ---------------------------------------------------------------
