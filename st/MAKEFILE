	$(BIN_DIR)\pr_drhal.$(DLL_EXT)

# All locations that receive a copy of the ini2cfg-generated st.cfg.
# Adding a new tool here is all that is needed to wire it in.
CFG_DESTS=\
	$(BIN_DIR)\st.cfg \
	$(UTIL_DIR)\inf2dat\st.cfg

.c.dll:
	$(CC) $(DLL_CC_OPTIONS) {$< }
	@move $&.$(OBJ_EXT)  $(OBJ_DIR)
	@move $&.$(DLL_EXT)  $(BIN_DIR)
	@move $&.$(LIB_EXT)   $(LIB_DIR)

.cpp.obj:
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**

.asm.obj:
	$(ASM) $(ASM_OPTS) $<, $@

$(BIN_DIR)\$(EXE_FILE): $(BIN_DIR)\$(HELP_FILE) $(BIN_DIR)\$(RES_FILE) $(CFG_DESTS) $(BIN_DIR)\st.ini $(BIN_DIR)\demo.ini $(BIN_DIR)\phones.csv $(OBJS) $(DLLS)
	$(LINK) $(LINK_OPTS) @&&!
$(STARTUP_OBJS) $(OBJS)
$*, ,$(LIBS), $(DEF_FILE)
!
!if $d(RUN)
	$(BIND) $(RTK_DIR)\run286b $(BIN_DIR)\$(EXE_FILE) -dll $(RTK_DIR)\doscalls $(RTK_DIR)\int33
	cfig286 $(BIN_DIR)\$(EXE_FILE) -NISTACK 10 -LDTSIZE 4096
!endif

$(BIN_DIR)\$(HELP_FILE): $(RES_DIR)\help.txt
	@genhelp $(RES_DIR)\help.txt $(HELP_FILE) > NUL
	@move $(HELP_FILE)	$(BIN_DIR) > NUL
	@move help.hpp $(INCLUDE_DIR) > NUL

# Zinc binary resource — the canonical RES.DAT is a tracked binary source
# in $(RES_DIR)\, edited interactively via DESIGN.EXE (Zinc Designer).
# This rule republishes it into $(BIN_DIR) so the runtime app finds it.
$(BIN_DIR)\$(RES_FILE): $(RES_DIR)\$(RES_FILE)
	@copy $(RES_DIR)\$(RES_FILE) $(BIN_DIR)\$(RES_FILE) > NUL

# Application config -- ini2cfg generates st.cfg from st.ini, then each
# tool's copy rule distributes it.  The ini2cfg invocation itself is
# done OUT-OF-BAND by build.sh / build.ps1 before make runs, because
# Borland MAKE 3.6 mis-propagates errorlevel from .bat-internal rules
# (see HANDOFF / TODO).  Same story for PH_INFO.DAT regen via mk_ph.bat.
$(BIN_DIR)\st.cfg: $(INI2CFG_DIR)\st.cfg
	@copy $(INI2CFG_DIR)\st.cfg $(BIN_DIR)\st.cfg > NUL
$(UTIL_DIR)\inf2dat\st.cfg: $(INI2CFG_DIR)\st.cfg
	@copy $(INI2CFG_DIR)\st.cfg $(UTIL_DIR)\inf2dat\st.cfg > NUL
$(BIN_DIR)\st.ini: $(INI2CFG_DIR)\st.ini
	@copy $(INI2CFG_DIR)\st.ini $(BIN_DIR)\st.ini > NUL
$(BIN_DIR)\demo.ini: $(INI2CFG_DIR)\demo.ini
	@copy $(INI2CFG_DIR)\demo.ini $(BIN_DIR)\demo.ini > NUL
# Real-number dataset for DEMO_ENGINE -- canonical source in util/inf2dat;
# DEMO_ENGINE::ParsePhones reads it from bin/ at startup.
$(BIN_DIR)\phones.csv: $(INF2DAT_DIR)\phones.csv
	@copy $(INF2DAT_DIR)\phones.csv $(BIN_DIR)\phones.csv > NUL
# Telephony binary database (bin\PH_INFO.DAT) and ini2cfg-generated
# st.cfg (util\ini2cfg\st.cfg) are produced OUT-OF-BAND by build.sh /
# build.ps1 before make runs.  MAKE rules used to invoke mk_ph.bat /
# mk_cfg.bat directly, but Borland MAKE 3.6 misreports errorlevel from
# .bat-internal commands and deletes the (just-created) target.  The
# bats work correctly when invoked from DOSBox-X directly, so build.sh
# does that.

# ============================================================================
# Explicit per-file source-path mapping
# ----------------------------------------------------------------------------
# Borland MAKE 3.6 doesn't support .PATH.x (see note near the top), so we
# tell MAKE where each source file lives via explicit dependency
# declarations. The .cpp.obj / .c.dll suffix rules above supply the build
# commands; these declarations only point MAKE at the source for each
# target. Order mirrors the OBJS / DLLS lists for 1-to-1 cross-checking.
#
# This block MUST live after the EXE rule so MAKE's default target stays
# $(BIN_DIR)\$(EXE_FILE) — Borland MAKE picks the first target it sees as
# default, and bodyless dependency declarations as default = silent no-op.
# ============================================================================

# --- OBJs (cpp -> obj) ---
# Each rule carries its own body because Borland MAKE 3.6's .cpp.obj
# suffix rule does not fire for path-prefixed targets (e.g. build\foo.obj).
# DLL targets DO work with the .c.dll suffix rule alone, but .cpp/.obj
# requires the explicit body to actually compile.
$(OBJ_DIR)\st.obj:       $(SOURCE_DIR)\st.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\bdisplay.obj: $(SOURCE_DIR)\ui\bdisplay.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\calc.obj:     $(SOURCE_DIR)\calc.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\calendar.obj: $(SOURCE_DIR)\calendar.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\cfg.obj:      $(SOURCE_DIR)\cfg.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\control.obj:  $(SOURCE_DIR)\ctrl\control.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
$(OBJ_DIR)\cstr.obj:     $(SOURCE_DIR)\cstr.cpp
	$(CC) $(OBJ_CC_OPTIONS) -o$@ $**
