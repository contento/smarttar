	MODULE g_perror.cpp
	MODULE g_phelp.cpp
	MODULE g_pnorm.cpp
	MODULE g_store.cpp
	MODULE g_time1.cpp
	MODULE g_win2.cpp
	LOCALUNKNOWN

	#----------------------------------------------------#
	# INTERRUPT HANDLERS AND DATA ITEMS IN CODE SEGMENTS #
	#----------------------------------------------------#
	LOCSYM      _MouseISR
	OKIFUNDEF   _MouseISR

	#---------------------------#
	# FREQUENTLY CALLED MODULES #
	#---------------------------#
	MODULE d_keybrd.cpp
	MODULE d_mouse.cpp
	MODULE d_mscdsp.cpp
	MODULE d_cursor.cpp
	MODULE i_mscat.cpp
	MODULE z_bitmap.cpp
	MODULE z_cursor.cpp
	MODULE z_device.cpp
	MODULE z_event.cpp
	MODULE z_keybrd.cpp
	MODULE z_list.cpp
	MODULE z_mouse.cpp

#-----------------#
# VIRTUAL MODULES #
#-----------------#
VMBEGINPAGES
  SEPARATE

	LOCALON
	MODULE z_map1.cpp
	MODULE z_map2.cpp
	MODULE g_time.cpp
