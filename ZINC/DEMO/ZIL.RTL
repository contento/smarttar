###########################################################################
#   Link script for virtualizing ZINC 3.5 interface library                #
############################################################################
SILENT

MODULEWARNINGSOFF

VIRTUALIZE CODE
CODECLASS  CODE

LIBRARY dos_zil 

#--------------#
# ROOT MODULES #
#--------------#

	#-------------------------------------#
	# MODULES TOO SMALL FOR VIRTUAL PAGES #
	#-------------------------------------#
	LOCALON
	MODULE g_bnum.cpp
	MODULE g_border.cpp
	MODULE g_cursor.cpp
	MODULE g_date.cpp
	MODULE g_date1.cpp
	MODULE g_device.cpp
	MODULE g_disp.cpp
	MODULE g_dsp.cpp
	MODULE g_event.cpp
	MODULE g_hotkey.cpp
	MODULE g_jump.cpp
	MODULE g_keybrd.cpp
